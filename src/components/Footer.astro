---
interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;

const linksLabel = lang === 'fr' ? 'Liens' : 'Navigation links';
const footerLabel = lang === 'fr' ? 'Liens et informations' : 'Links and information';
const backToTop = lang === 'fr' ? 'Retour en haut' : 'Back to top';

const whisper = lang === 'fr'
  ? "Quand je ne suis pas en réunion, je suis probablement sur ma moto ou derrière un objectif."
  : "When I'm not in a meeting, I'm probably on my motorbike or behind a lens.";

const humor = lang === 'fr'
  ? "Astro + Claude Code. WCAG 2.2. Zéro JS côté client. Le web comme avant, en mieux."
  : "Astro + Claude Code. WCAG 2.2. Zero client-side JS. The web like it used to be, only better.";
---

<footer class="footer" role="group" aria-label={footerLabel}>
  <div class="footer-contact">
    <nav class="footer-links" aria-label={linksLabel}>
      <a href="https://www.linkedin.com/in/thomasvuillaume/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:contact@thomasvuillaume.fr">Email</a>
      <a href="https://github.com/thomasvuillaume" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/ThomasVuillaume/thomasvuillaume.github.io" target="_blank" rel="noopener">Source</a>
    </nav>
    <p class="footer-whisper">{whisper}</p>
  </div>
  <input type="checkbox" id="egg" class="egg-toggle" aria-label="Surprise" />
  <div class="footer-arrows">
    <a href="#main-content" aria-label={backToTop}>&#8593;</a>
    <label for="egg">&#8595;</label>
  </div>
  <div class="egg-content">
    <p class="footer-humor">{humor}</p>
  </div>
</footer>
