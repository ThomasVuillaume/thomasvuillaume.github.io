---
import { getCollection } from 'astro:content';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;

const label = lang === 'fr' ? 'Contributions' : 'Contributions';
const sectionTitle = lang === 'fr' ? 'Contributions' : 'Contributions';

const allEntries = await getCollection('timeline');
const entries = allEntries
  .filter((e) => e.data.lang === 'both' || e.data.lang === lang)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

function displayDate(date: string): string {
  const map: Record<string, string> = {
    '2026-01': '2026',
    '2025-01': '2025',
    '2024-10': '2024',
    '2021-01': '2021',
    '2020-01': '2020',
    '2018-01': '2018',
    '2014-11': '2014',
  };
  return map[date] || date.slice(0, 4);
}

function getTitle(entry: any): string {
  if (lang === 'en' && entry.data.titleEn) return entry.data.titleEn;
  return entry.data.title;
}

function getSub(entry: any): string | undefined {
  if (lang === 'en' && entry.data.subEn) return entry.data.subEn;
  return entry.data.sub;
}
---

{entries.length > 0 && (
  <section class="section" aria-label={label}>
    <h2 class="section-title">{sectionTitle}</h2>
    <ul class="contributions">
      {entries.map((entry) => (
        <li class:list={[{ highlight: entry.data.highlight }]}>
          <span class="year">{displayDate(entry.data.date)}</span>
          <span class="desc">
            {getTitle(entry)}
            {entry.data.url && getSub(entry) && (
              <span class="desc-sub">
                <a href={entry.data.url} target="_blank" rel="noopener">{getSub(entry)}</a>
              </span>
            )}
            {!entry.data.url && getSub(entry) && (
              <span class="desc-sub">{getSub(entry)}</span>
            )}
          </span>
        </li>
      ))}
    </ul>
  </section>
)}
