---
interface Props {
  lang: 'fr' | 'en';
  title: string;
  description: string;
  canonicalPath: string;
}

const { lang, title, description, canonicalPath } = Astro.props;
const site = 'https://www.thomasvuillaume.fr';
const canonicalUrl = `${site}${canonicalPath}`;
const jobTitle = lang === 'fr' ? 'Directeur Stratégie & Technique' : 'Director of Strategy & Engineering';

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="fr" href={`${site}/`} />
  <link rel="alternate" hreflang="en" href={`${site}/en/`} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${site}/og-image.jpg`} />
  <meta property="og:site_name" content="Thomas Vuillaume" />
  <meta property="og:locale" content="fr_FR" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${site}/og-image.jpg`} />
  <meta name="twitter:site" content="@thomasvuillaume" /> <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Thomas Vuillaume",
    "jobTitle": jobTitle,
    "worksFor": {
      "@type": "Organization",
      "name": "SOLENT",
      "url": "https://www.solent.fr"
    },
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": "École Centrale Lyon"
    },
    "url": site,
    "sameAs": [
      "https://www.linkedin.com/in/thomasvuillaume",
      "https://github.com/thomasvuillaume"
    ]
  })} />
</head>
<body>
  <slot />
</body>
</html>
